        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", json.access_token);",
                  "  }",
                  "} catch (e) {}"
